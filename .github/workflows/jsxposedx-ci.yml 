name: JsxposedX CI/CD

on:
  push:
    branches: [ main, master ]
  pull_request:
    branches: [ main, master ]
  workflow_dispatch:  # 允许手动触发

jobs:
  build:
    runs-on: ubuntu-latest
    
    steps:
    - name: Checkout code
      uses: actions/checkout@v4
      
    - name: Setup Java
      uses: actions/setup-java@v4
      with:
        distribution: 'temurin'
        java-version: '17'
        
    - name: Setup Flutter
      uses: subosito/flutter-action@v2
      with:
        flutter-version: '3.19.0'  # 根据项目实际需求调整版本
        channel: stable
        
    - name: Install dependencies
      run: flutter pub get
      
    - name: Analyze code
      run: flutter analyze
      
    - name: Run tests
      run: flutter test
      
    - name: Build API100 App Bundle
      run: flutter build appbundle --flavor api100 --release
      
    - name: Build API101 APK
      run: flutter build apk --flavor api101 --release
      
    - name: Upload API100 App Bundle artifact
      uses: actions/upload-artifact@v4
      with:
        name: jsxposedx-api100-appbundle
        path: build/app/outputs/bundle/api100Release/app-api100-release.aab
        retention-days: 7
        
    - name: Upload API101 APK artifact
      uses: actions/upload-artifact@v4
      with:
        name: jsxposedx-api101-apk
        path: build/app/outputs/flutter-apk/app-api101-release.apk
        retention-days: 7
        
    # 可选：使用Gradle直接构建的步骤
    - name: Build with Gradle (API100)
      run: ./gradlew :app:bundleApi100Release
      
    - name: Build with Gradle (API101)
      run: ./gradlew :app:assembleApi101Release
      
    - name: Upload Gradle build artifacts
      uses: actions/upload-artifact@v4
      with:
        name: gradle-builds
        path: |
          android/app/build/outputs/bundle/api100Release/
          android/app/build/outputs/apk/api101/release/
        retention-days: 7
